@model Post 
@{
    ViewData["Title"] = Model.Title;
}
<style>
    .content-wrapeer {
        padding: 20px;
        max-width: 1000px;
        margin: 0 auto;
        font-family: sans-serif
    }

    .feature-image{
        width:100%;
        height:500px;
        object-fit:cover;
        margin-bottom:20px;


    }
</style>

@if(User.IsInRole("Admin"))
{
<div class=" text-end">
    <a class="btn btn-secondary my-3"asp-controller="Post" asp-action="Edit" asp-route-id="@Model.Id">Edit Post</a>

    <a class="btn btn-danger mx-3 my-3" asp-controller="Post" asp-action="Delete" asp-route-id="@Model.Id">Delete Post</a>

</div>
}


<div class="content-wrapeer">
    <h1 >@Model.Title></h1>
    <p><span class="badge bg-primary">By:</span> @Model.Author |<span class="badge bg-primary">
    Published on </span>@Model.PublishedDate.ToString("MMMM dd,yyyy") </p>

    <p><span class="badge bg-secondary">Category</span> @Model.Category.Name</p>

   <img src="@Model.FeatureImagePath" alt="@Model.Title" class="feature-image"/>
    
   <hr />
   <div>@Html.Raw(Model.Content)</div>
    
   <hr/>
   @if(Model.Comments.Any())
    {
        <div id="commentSection">
            @foreach (var comment in Model.Comments)
            {
                <div class=" card  mb-3 shadow-sm">

                  <div class="card-body"></div>
                  <h5 class=" card-Title">@comment.UserName</h5>
                  <p class=" card-text text-muted  ">@comment.CommentDate.ToString("MMMM,dd,yyyy")</p>
                  <p class="card-text">@comment.Content </p>

                </div> 
            }
        </div>
        

    }
    else
    {
        <p class ="text-muted">No comment yet. Be the first to comment </p>
    }

    @if (User.Identity.IsAuthenticated)
    {



        <h4>Add a Comment</h4>
        <form id="commentForm">

        <div class=" form-group">
            <label for=" Username">Name</label>
            <input id="Username" name="Username" required />

        </div>

        <div class=" form-group">
            <label for=" Content">Content</label>
            <textarea for="Content" id="Content"  name="Content" rows="3" required class=" form-control"></textarea>
        </div>

        <button type="submit" class="btn btn-primary mt-2 p-2 rounded">Submit Comment</button>

    </form>


    }
</div>

       @section Scripts{
           <script>
               $(document).ready(function(){

                 $("#commentForm").on('submit', function (event) {

                       event.preventDefault(); 
                       var userName = $("#Username").val();
                       var content = $("#Content").val();
                       var postId   = @Model.Id;

                       console.log(userName, content,postId)

                       $.ajax({
                           
                       //https:localhost:7192/Post/Add/AddComment
                           url:'@Url.Action("AddComment","Post")',
                           type:'POST',
                           contentType:'application/json',
                           data:JSON.stringify({
                               Username:userName,
                               Content:content, 
                               postId:postId    

                           }),
                             

                              success :function(response){
                                    $('#commentForm')[0].reset();
                                    $('#commentSection').append(
                                        `
                             <div class=" card  mb-3 shadow-sm">
                                 <div class="card-body">
                                 <h5 class=" card-Title">${response.userName}</h5>
                                 <p class=" card-text text-muted">${response.commentDate}</p>
                                 <p class="card-text">${response.content} </p>
                             </div>
                      </div>
                                        `
                                    )
                              }

                            
                       })

                   });

              

               });

           </script>
