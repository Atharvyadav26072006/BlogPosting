@using SyncSyntax.Helpers
@model IEnumerable<Post>

@{
    ViewData["Title"] = "Blog Posts";
}

<div class="text-center m-3">
    @if (ViewBag.Categories != null)
    {
        foreach (var category in ViewBag.Categories)
        {
            <a asp-controller="Post"
               asp-action="Index"
               asp-route-categoryId="@category.Id"
               class="badge bg-warning text-dark text-decoration-none ms-2">
                @category.Name
            </a>
        }
    }
</div>

@if (User.IsInRole("Admin"))
{
    <div class="text-end my-2">
        <a class="btn btn-primary"
           asp-controller="Post"
           asp-action="Create">
            Create New Post
        </a>
    </div>
}

<div class="row row-cols-1 row-cols-md-3 g-4">

    @foreach (var post in Model)
    {
        var imagePath = string.IsNullOrWhiteSpace(post.FeatureImagePath)
            ? "/images/default-post.jpg"
            : post.FeatureImagePath.Replace("\\", "/");

        if (!imagePath.StartsWith("/"))
        {
            imagePath = "/images/" + imagePath;
        }

        var content = RemoveHtmlTagHelper.RemoveHtmlTags(post.Content ?? "");

        <div class="col">
            <div class="card h-100 border-0 shadow-lg rounded-1">

                <img src="@imagePath"
                     class="card-img-top"
                     alt="@post.Title"
                     style="height:300px; object-fit:cover;"
                     onerror="this.onerror=null;this.src='/images/default-post.jpg';" />

                <div class="card-body">
                    <h5 class="card-title">@post.Title</h5>

                    <p class="text-muted mb-2">
                        Published on @post.PublishedDate.ToString("MMM dd, yyyy")
                    </p>

                    <p class="card-text">
                        @(content.Length > 100
                            ? content.Substring(0, 100) + "....."
                            : content)
                    </p>

                    @if (post.Category != null)
                    {
                        <span class="badge bg-secondary">
                            @post.Category.Name
                        </span>
                    }
                </div>

                <div class="card-footer d-flex justify-content-between align-items-center">
                    <a class="btn btn-primary btn-sm"
                       asp-controller="Post"
                       asp-action="Detail"
                       asp-route-id="@post.Id">
                        Read More
                    </a>

                    <div class="text-muted">
                        By @post.Author
                    </div>
                </div>

            </div>
        </div>
    }

</div>