@model EditViewModel

@{
    ViewData["Title"] = "Edit Post";
}

<style>
    .content-wrapper {
        padding: 20px;
        max-width: 1000px;
        margin: 0 auto;
        font-family: sans-serif;
    }

    .form-group {
        margin-bottom: 15px;
    }
</style>

<div class="content-wrapper">

    <div class="row">
        <div class="col-6">
            <h2>@ViewData["Title"]</h2>
        </div>

        <div class="col-6 text-end">
            <a class="btn btn-primary"
               asp-action="Index"
               asp-controller="Post">
                Back To List
            </a>
        </div>
    </div>

    <hr />

    <form asp-action="Edit"
          asp-controller="Post"
          method="post"
          enctype="multipart/form-data">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="All"
             class="text-danger">
        </div>

        <input asp-for="Post.Id" type="hidden" />

        <div class="form-group">
            <label asp-for="Post.Title"
                   class="form-label">
            </label>

            <input asp-for="Post.Title"
                   class="form-control" />

            <span asp-validation-for="Post.Title"
                  class="text-danger">
            </span>
        </div>

        <div class="form-group">
            <label asp-for="Post.CategoryId"
                   class="form-label">
            </label>

            <select asp-for="Post.CategoryId"
                    asp-items="Model.Categories"
                    class="form-control">

                <option value="">Select Category</option>

            </select>

            <span asp-validation-for="Post.CategoryId"
                  class="text-danger">
            </span>
        </div>

        <div class="form-group">
            <label asp-for="Post.Author"
                   class="form-label">
            </label>

            <input asp-for="Post.Author"
                   class="form-control" />

            <span asp-validation-for="Post.Author"
                  class="text-danger">
            </span>
        </div>

        <div class="form-group">
            <label asp-for="Post.Content"
                   class="form-label">
            </label>

            <textarea asp-for="Post.Content"
                      class="form-control"
                      rows="8">
            </textarea>

            <span asp-validation-for="Post.Content"
                  class="text-danger">
            </span>
        </div>

        <div class="form-group">
            <label asp-for="FeatureImage"
                   class="form-label">
            </label>

            <input asp-for="FeatureImage"
                   type="file"
                   accept=".jpg,.jpeg,.png"
                   class="form-control" />

            <span asp-validation-for="FeatureImage"
                  class="text-danger">
            </span>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Post.FeatureImagePath))
        {
            <div class="form-group">
                <p>Current Image:</p>

                <img src="@Model.Post.FeatureImagePath"
                     alt="Current post image"
                     style="max-width: 250px; height: auto;" />
            </div>
        }

        <button type="submit"
                class="btn btn-primary mt-2">
            Update
        </button>

        <a asp-action="Index"
           asp-controller="Post"
           class="btn btn-secondary mt-2">
            Cancel
        </a>

    </form>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script src="https://cdn.tiny.cloud/1/<script src="https://cdn.tiny.cloud/1/bk25e0suer3ivmdg2e3ve2e0nis0je1f68ix9a02xemylf0m/tinymce/8/tinymce.min.js" referrerpolicy="origin" crossorigin="anonymous"></script>
/tinymce/8/tinymce.min.js"
            referrerpolicy="origin"
            crossorigin="anonymous">
    </script>

    <script>
        tinymce.init({
            selector: '#Post_Content',
            height: 400,
            menubar: true,
            plugins: 'lists link image table code',
            toolbar: 'undo redo | bold italic | bullist numlist | link image | table | code'
        });
    </script>
}